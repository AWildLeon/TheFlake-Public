#!/usr/bin/env bash
# Recursively rekey agenix secrets.
#
# Finds every secrets.nix under one or more roots and runs `agenix -r` in that
# file's directory. This is useful for this repository's host-local secret
# layout, where each host owns its own secrets.nix and secrets/*.age files.
#
# Usage:
#   rekey-recursive [options] [root ...]
#
# Roots default to the repository root. Relative roots are resolved relative to
# GIT_ROOT/the git top-level.
#
# Options:
#   -n, --dry-run       Only print directories that would be rekeyed
#   -c, --continue      Continue after a failed directory and report all errors
#   -v, --verbose       Print the agenix command for each directory
#   --agenix-bin PATH   agenix executable to use (default: agenix from PATH)
#   -h, --help          Show this help
#
# Notes:
#   - Exports GIT_ROOT so per-host secrets.nix files can import shared user keys.
#   - Does not decrypt secrets to stdout.
#   - Requires your local age identity to be able to decrypt the selected files.

set -euo pipefail

usage() {
  cat <<'EOF'
Recursively rekey agenix secrets.

Finds every secrets.nix under one or more roots and runs `agenix -r` in that
file's directory. This is useful for this repository's host-local secret
layout, where each host owns its own secrets.nix and secrets/*.age files.

Usage:
  rekey-recursive [options] [root ...]

Roots default to the repository root. Relative roots are resolved relative to
GIT_ROOT/the git top-level.

Options:
  -n, --dry-run       Only print directories that would be rekeyed
  -c, --continue      Continue after a failed directory and report all errors
  -v, --verbose       Print the agenix command for each directory
  --agenix-bin PATH   agenix executable to use (default: agenix from PATH)
  -h, --help          Show this help

Notes:
  - Exports GIT_ROOT so per-host secrets.nix files can import shared user keys.
  - Does not decrypt secrets to stdout.
  - Requires your local age identity to be able to decrypt the selected files.
EOF
}

if git rev-parse --show-toplevel >/dev/null 2>&1; then
  GIT_ROOT="${GIT_ROOT:-$(git rev-parse --show-toplevel)}"
elif [[ -n "${GIT_ROOT:-}" ]]; then
  GIT_ROOT="$(cd "$GIT_ROOT" && pwd)"
else
  echo "Error: not in a git repository and GIT_ROOT is not set" >&2
  exit 1
fi
export GIT_ROOT

DRY_RUN=0
CONTINUE=0
VERBOSE=0
AGENIX_BIN="agenix"
ROOTS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run)
      DRY_RUN=1
      shift
      ;;
    -c|--continue)
      CONTINUE=1
      shift
      ;;
    -v|--verbose)
      VERBOSE=1
      shift
      ;;
    --agenix-bin)
      [[ $# -ge 2 ]] || { echo "Error: --agenix-bin requires a path" >&2; exit 1; }
      AGENIX_BIN="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        ROOTS+=("$1")
        shift
      done
      ;;
    -*)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      ROOTS+=("$1")
      shift
      ;;
  esac
done

if [[ ${#ROOTS[@]} -eq 0 ]]; then
  ROOTS=("$GIT_ROOT")
fi

if [[ $DRY_RUN -eq 0 ]]; then
  command -v "$AGENIX_BIN" >/dev/null 2>&1 || {
    echo "Error: agenix executable not found: $AGENIX_BIN" >&2
    exit 1
  }

fi

abs_roots=()
for root in "${ROOTS[@]}"; do
  if [[ "$root" = /* ]]; then
    abs_root="$root"
  else
    abs_root="$GIT_ROOT/$root"
  fi

  if [[ ! -e "$abs_root" ]]; then
    echo "Error: root does not exist: $root" >&2
    exit 1
  fi

  abs_roots+=("$(cd "$abs_root" && pwd)")
done

secret_file_list="$(mktemp)"
trap 'rm -f "$secret_file_list"' EXIT

find "${abs_roots[@]}" \
  -path '*/.git' -prune -o \
  -path '*/result' -prune -o \
  -name secrets.nix -type f -print0 \
  | sort -z > "$secret_file_list"

mapfile -d '' secret_files < "$secret_file_list"

if [[ ${#secret_files[@]} -eq 0 ]]; then
  echo "No secrets.nix files found." >&2
  exit 0
fi

failures=()

for secrets_file in "${secret_files[@]}"; do
  dir="$(dirname "$secrets_file")"
  rel="${dir#$GIT_ROOT/}"
  [[ "$rel" == "$dir" ]] && rel="$dir"

  if [[ $DRY_RUN -eq 1 ]]; then
    echo "$rel"
    continue
  fi

  echo "==> Rekeying $rel"
  if [[ $VERBOSE -eq 1 ]]; then
    echo "    (cd $rel && $AGENIX_BIN -r)"
  fi

  if ! (cd "$dir" && "$AGENIX_BIN" -r); then
    failures+=("$rel")
    if [[ $CONTINUE -eq 0 ]]; then
      echo "Error: rekey failed in $rel" >&2
      exit 1
    fi
  fi
done

if [[ ${#failures[@]} -gt 0 ]]; then
  echo "" >&2
  echo "Rekey failed in ${#failures[@]} director$( [[ ${#failures[@]} -eq 1 ]] && echo y || echo ies ):" >&2
  printf '  %s\n' "${failures[@]}" >&2
  exit 1
fi

if [[ $DRY_RUN -eq 0 ]]; then
  echo "Done. Rekeyed ${#secret_files[@]} secrets.nix director$( [[ ${#secret_files[@]} -eq 1 ]] && echo y || echo ies )."
fi
